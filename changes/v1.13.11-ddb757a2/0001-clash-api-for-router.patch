From 01d5cd90896c0b99217688ab803d110d10616f86 Mon Sep 17 00:00:00 2001
From: sssuuwww <sssuuwww@nobody.com>
Date: Sun, 10 May 2026 03:22:10 +0800
Subject: [PATCH] clash api for router

---
 experimental/clashapi/configs.go | 23 +++++++++++++++++++++--
 experimental/clashapi/restart.go | 19 +++++++++++++++++++
 experimental/clashapi/server.go  |  1 +
 3 files changed, 41 insertions(+), 2 deletions(-)
 create mode 100644 experimental/clashapi/restart.go

diff --git a/experimental/clashapi/configs.go b/experimental/clashapi/configs.go
index 8ae1d258..165d6866 100644
--- a/experimental/clashapi/configs.go
+++ b/experimental/clashapi/configs.go
@@ -2,6 +2,7 @@ package clashapi
 
 import (
 	"net/http"
+	"os"
 
 	"github.com/sagernet/sing-box/log"
 
@@ -12,7 +13,7 @@ import (
 func configRouter(server *Server, logFactory log.Factory) http.Handler {
 	r := chi.NewRouter()
 	r.Get("/", getConfigs(server, logFactory))
-	r.Put("/", updateConfigs)
+	r.Put("/", putConfigs)
 	r.Patch("/", patchConfigs(server))
 	return r
 }
@@ -31,6 +32,8 @@ type configSchema struct {
 	LogLevel string         `json:"log-level"`
 	IPv6     bool           `json:"ipv6"`
 	Tun      map[string]any `json:"tun"`
+	Path     string         `json:"path"`
+	Payload  string         `json:"payload"`
 }
 
 func getConfigs(server *Server, logFactory log.Factory) func(w http.ResponseWriter, r *http.Request) {
@@ -66,6 +69,22 @@ func patchConfigs(server *Server) func(w http.ResponseWriter, r *http.Request) {
 	}
 }
 
-func updateConfigs(w http.ResponseWriter, r *http.Request) {
+func putConfigs(w http.ResponseWriter, r *http.Request) {
+	var newConfig configSchema
+	err := render.DecodeJSON(r.Body, &newConfig)
+	if err != nil {
+		render.Status(r, http.StatusBadRequest)
+		render.JSON(w, r, ErrBadRequest)
+		return
+	}
+	if newConfig.Payload != "" {
+		err = os.WriteFile("/tmp/sing-box-running-config.json", []byte(newConfig.Payload), 0o644)
+		if err != nil {
+			render.Status(r, http.StatusInternalServerError)
+			render.JSON(w, r, render.M{"message": err.Error()})
+			return
+		}
+		os.Exit(0)
+	}
 	render.NoContent(w, r)
 }
diff --git a/experimental/clashapi/restart.go b/experimental/clashapi/restart.go
new file mode 100644
index 00000000..38d241aa
--- /dev/null
+++ b/experimental/clashapi/restart.go
@@ -0,0 +1,19 @@
+package clashapi
+
+import (
+	"net/http"
+	"os"
+
+	"github.com/go-chi/chi/v5"
+	"github.com/sagernet/sing-box/log"
+)
+
+func restartRouter(server *Server, logFactory log.Factory) http.Handler {
+	r := chi.NewRouter()
+	r.Post("/", restart)
+	return r
+}
+
+func restart(w http.ResponseWriter, r *http.Request) {
+	os.Exit(0)
+}
diff --git a/experimental/clashapi/server.go b/experimental/clashapi/server.go
index ec40a95f..f16c743e 100644
--- a/experimental/clashapi/server.go
+++ b/experimental/clashapi/server.go
@@ -119,6 +119,7 @@ func NewServer(ctx context.Context, logFactory log.ObservableFactory, options op
 		r.Get("/traffic", traffic(s.ctx, trafficManager))
 		r.Get("/version", version)
 		r.Mount("/configs", configRouter(s, logFactory))
+		r.Mount("/restart", restartRouter(s, logFactory))
 		r.Mount("/proxies", proxyRouter(s, s.router))
 		r.Mount("/rules", ruleRouter(s.router))
 		r.Mount("/connections", connectionRouter(s.ctx, s.router, trafficManager))
-- 
